{
  "name": "@agentsystemlabs/core",
  "version": "0.50.2",
  "description": "Install AgentSystem skills into any project — works with Claude Code, Codex, Cursor, OpenCode, or any tool that reads SKILL.md files.",
  "type": "module",
  "bin": {
    "agentsystem": "cli/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "check:routing": "node scripts/check-skill-routing.mjs",
    "prepublishOnly": "npm test && node cli/index.js --version"
  },
  "files": [
    "cli",
    "plugins",
    ".claude-plugin"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "12.1.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "agent-skills",
    "agentsystem",
    "anthropic",
    "opencode",
    "codex",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentSystemLabs/core.git"
  },
  "homepage": "https://github.com/AgentSystemLabs/core#readme",
  "bugs": {
    "url": "https://github.com/AgentSystemLabs/core/issues"
  },
  "license": "MIT"
}
