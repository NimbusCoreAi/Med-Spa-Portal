# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_CONNECT=price_xxx
STRIPE_PRICE_INTELLIGENCE=price_xxx

# ─── Postmark ───
POSTMARK_API_TOKEN=xxx
POSTMARK_FROM_EMAIL=noreply@yourdomain.com

# ─── Twilio ───
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+15125551234

# ─── Connect API ───
CONNECT_API_URL=http://localhost:3001
CONNECT_API_KEY=your-api-key

# ─── Connect API Rate Limiting (Phase 2C) ───
# Set to "true" to allow requests through when Upstash Redis is unavailable
# (dev/staging only — production should leave this unset so limiting fails closed).
RATE_LIMIT_FAIL_OPEN=false

# ─── Connect API SMS Guards ───
# Per-clinic daily SMS cap (default 50). Set via SMS_DAILY_LIMIT_PER_CLINIC.
SMS_DAILY_LIMIT_PER_CLINIC=50
# Comma-separated allowlist of hosts permitted in SMS intake_url (e.g. intake.yourapp.com,yourapp.com).
# When unset, all URLs are allowed (production should set this to prevent phishing links).
CONNECT_INTAKE_URL_ALLOWLIST=

# ─── Optional ───
PHI_ENABLED=false

# ─── Upstash Redis (Phase 2C — Rate Limiting) ───
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── MCP Server (Phase 3D — AI Agent Integration) ───
# Used by apps/mcp-server to authenticate Connect API calls
# CONNECT_API_URL and CONNECT_API_KEY (above) are shared

# ─── ML Server (Phase 4D — Python Prediction Server) ───
ML_SERVER_URL=http://localhost:8000
