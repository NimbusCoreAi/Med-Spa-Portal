# ─── App ───────────────────────────────────────────────────
# Public URL of the deployed app (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────────
# Public (exposed to browser — required for client auth + middleware)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side fallback (used by @baseplate/core when NEXT_PUBLIC_ vars are absent)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Service-role key (server only — bypasses RLS, used by patient-facing API routes
# and the Stripe webhook). NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Subscription pricing (create products in Stripe Dashboard → Products)
STRIPE_PRICE_CONNECT=
STRIPE_PRICE_INTELLIGENCE=

# ─── Postmark (Email) ─────────────────────────────────────
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=

# ─── Twilio (SMS) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
